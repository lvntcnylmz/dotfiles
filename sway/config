include ~/.config/sway/configs/basic
include ~/.config/sway/configs/output
include ~/.config/sway/configs/variables
include ~/.config/sway/configs/bindsym
include /etc/sway/config.d/*

## auto-start apps
# 1. Audio system (pipewire first, then dependents)
exec pipewire
exec pipewire-pulse
exec wireplumber

# 2. X resources (must be loaded before applications start)
exec xrdb -load $HOME/.Xresources

# 3. Display & screen management
exec kanshi

# 4. Brightness & color
exec wluma
exec gammastep-indicator

# 5. Input method
exec fcitx5 -dr

# 6. Terminal server (may be used by other applications)
exec foot --server

# 7. Media
exec playerctld daemon

# 8. Notification & tiling
exec swaync
exec autotiling
exec swayosd-server

# 9. Tray applications
exec nm-applet --indicator
exec kdeconnect-indicator

# 10. Last — delayed scripts
exec --no-startup-id mpv $HOME/.config/sway/audio/pc_startup.ogg 2>/dev/null
exec sleep 5 && $HOME/.config/sway/scripts/layout.sh
exec sleep 5 && $HOME/.config/sway/scripts/wallpaper.sh
